{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BookMind",
  "version": "0.1.0",
  "identifier": "com.bookmind.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BookMind",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true,
        "decorations": false,
        "center": true,
        "backgroundColor": [23, 19, 15, 255]
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$LOCALDATA/BookMindData/library/epub-assets/**",
          "$LOCALDATA/BookMindData/library/covers/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
